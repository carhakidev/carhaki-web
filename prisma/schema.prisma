generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  phoneNumber  String?  @map("phone_number")
  isVerified   Boolean  @default(false) @map("is_verified")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  orders  Order[]
  reports Report[]

  @@map("users")
}

model Order {
  id                 String    @id @default(cuid())
  userId             String    @map("user_id")
  vin                String
  amountNgn          Int       @map("amount_ngn")
  paystackReference  String    @unique @map("paystack_reference")
  paystackAccessCode String?   @map("paystack_access_code")
  paymentStatus      String    @default("PENDING") @map("payment_status")
  paidAt             DateTime? @map("paid_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  user   User    @relation(fields: [userId], references: [id])
  report Report?

  @@map("orders")
}

model Report {
  id              String    @id @default(cuid())
  orderId         String    @unique @map("order_id")
  userId          String    @map("user_id")
  vin             String
  status          String    @default("PENDING")
  overallGrade    String?   @map("overall_grade")
  riskScore       Int?      @map("risk_score")
  gradeLabel      String?   @map("grade_label")
  gradeColour     String?   @map("grade_colour")
  processedData   Json?     @map("processed_data")
  aiSummary       String?   @map("ai_summary")
  rawClearvinData Json?     @map("raw_clearvin_data")
  rawNhtsaData    Json?     @map("raw_nhtsa_data")
  shareToken      String    @unique @default(cuid()) @map("share_token")
  isPublic        Boolean   @default(false) @map("is_public")
  completedAt     DateTime? @map("completed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@map("reports")
}
